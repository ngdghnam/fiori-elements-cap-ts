{
  "_version": "1.84.0",
  "sap.app": {
    "id": "cnma.learningplatform.cnmalearningplatform",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:ovp",
      "version": "1.24.0",
      "toolsId": "d93a16f3-fde8-4898-ac29-403a5c3b6e1f"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v2/api/cnma/LEARNINGHUB_SRV/",
        "type": "OData",
        "useBatch": false,
        "settings": {
          "annotations": [],
          "odataVersion": "2.0",
          "localUri": "localService/metadata.xml"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "LearningPlatform-display": {
          "semanticObject": "LearningPlatform",
          "action": "display",
          "title": "{{LearningPlatform-display.flpTitle}}",
          "subTitle": "{{LearningPlatform-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.150.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.ovp": {},
        "sap.ui.rta": {},
        "sap.ui.layout": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "cnma.learningplatform.cnmalearningplatform.i18n.i18n"
        }
      },
      "mainModel": {
        "dataSource": "mainService",
        "type": "sap.ui.model.odata.v2.ODataModel",
        "preload": true,
        "settings": {
          "defaultOperationMode": "Server",
          "defaultBindingMode": "TwoWay",
          "defaultCountMode": "Request",
          "useBatch": false
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [],
      "targets": {}
    }
  },
  "sap.ovp": {
    "globalFilterModel": "mainModel",
    "globalFilterEntitySet": "Course",
    "containerLayout": "resizable",
    "enableLiveFilter": true,
    "considerAnalyticalParameters": false,
    "cards": {
      "userInfoCard": {
        "model": "mainModel",
        "template": "cnma.learningplatform.cnmalearningplatform.ext.customCards.UserInfo",
        "settings": {
          "title": "User Profile",
          "entitySet": "User"
        }
      },
      "continueLearningCard": {
        "model": "mainModel",
        "template": "sap.ovp.cards.list",
        "settings": {
          "title": "Continue Learning",
          "subTitle": "Lectures you are currently taking",
          "entitySet": "LectureProgress",
          "listType": "extended",
          "listFlavor": "standard",
          "annotationPath": "com.sap.vocabularies.UI.v1.LineItem#ContinueLearning",
          "selectionAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionVariant#ContinueLearning"
        }
      },
      "courseProgressCard": {
        "model": "mainModel",
        "template": "sap.ovp.cards.list",
        "settings": {
          "title": "Course Progress",
          "entitySet": "Course",
          "listType": "extended",
          "listFlavor": "standard",
          "annotationPath": "com.sap.vocabularies.UI.v1.LineItem#CourseProgress"
        }
      },
      "latestCoursesCard": {
        "model": "mainModel",
        "template": "sap.ovp.cards.list",
        "settings": {
          "title": "Latest Courses",
          "subTitle": "Discover new courses",
          "entitySet": "Course",
          "listType": "condensed",
          "listFlavor": "standard",
          "annotationPath": "com.sap.vocabularies.UI.v1.LineItem#LatestCourses",
          "selectionAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionVariant#LatestCourses"
        }
      },
      "latestArticlesCard": {
        "model": "mainModel",
        "template": "sap.ovp.cards.list",
        "settings": {
          "title": "Latest Articles",
          "subTitle": "Knowledge Sharing",
          "entitySet": "Article",
          "listType": "condensed",
          "listFlavor": "standard",
          "annotationPath": "com.sap.vocabularies.UI.v1.LineItem#LatestArticles",
          "selectionAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionVariant#LatestArticles"
        }
      },
      "coursesByCategoryCard": {
        "model": "mainModel",
        "template": "sap.ovp.cards.charts.analytical",
        "settings": {
          "title": "Courses by Category",
          "entitySet": "Course",
          "chartAnnotationPath": "com.sap.vocabularies.UI.v1.Chart#CoursesByCategory"
        }
      },
      "quickLinksCard": {
        "model": "mainModel",
        "template": "sap.ovp.cards.linklist",
        "settings": {
          "title": "Admin Navigation",
          "subTitle": "Manage System Data",
          "listFlavor": "standard",
          "staticContent": [
            {
              "title": "Manage Courses",
              "targetUri": "../../course_manager/webapp/index.html",
              "icon": "sap-icon://education"
            },
            {
              "title": "Manage Tags",
              "targetUri": "../../tag_manager/webapp/index.html",
              "icon": "sap-icon://tag"
            }
          ]
        }
      }
    },
    "globalFilterControlType": "MacroFilterBar"
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
