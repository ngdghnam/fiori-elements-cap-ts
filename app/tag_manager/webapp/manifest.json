{
  "_version": "1.49.0",
  "sap.app": {
    "id": "cnma.learningplatform.tagmanager",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "Tag Management",
    "description": "Manage Tags",
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/api/cnma/LEARNINGHUB_SRV/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "TagManager-display": {
          "semanticObject": "TagManager",
          "action": "display",
          "title": "Tag Management",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.108.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "cnma.learningplatform.tagmanager.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "TagList",
          "target": "TagList"
        },
        {
          "pattern": "Tag({key}):?query:",
          "name": "TagObjectPage",
          "target": "TagObjectPage"
        }
      ],
      "targets": {
        "TagList": {
          "type": "Component",
          "id": "TagList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "Tag",
              "navigation": {
                "Tag": {
                  "detail": {
                    "route": "TagObjectPage"
                  }
                }
              }
            }
          }
        },
        "TagObjectPage": {
          "type": "Component",
          "id": "TagObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "Tag"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
